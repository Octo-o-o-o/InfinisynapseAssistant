{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "lib": ["ES2023", "DOM"],
    "types": ["node"]
  },
  "include": ["src", "test", "examples"],
  // express-proxy 依赖可选的 express（peerDependenciesMeta.optional）；未安装 express 时跳过它的类型检查
  "exclude": ["examples/express-proxy.ts"]
}
